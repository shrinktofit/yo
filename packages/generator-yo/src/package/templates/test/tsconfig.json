{
  "extends": "@<%= scopeName %>/workflow/tsconfig/test",
  "include": ["."],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "lib",
    "types": [
      <%- types.map(t => '"' + t + '"').join(',\n      ') %>
    ],
    "skipLibCheck": true,
    "paths": {
      "@src/*": ["../src/*"]
    }
  },
  "references": [{"path": ".."}]
}
